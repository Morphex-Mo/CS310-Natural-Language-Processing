{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build LaTeX PDF (XeLaTeX)",
      "type": "shell",
      "command": "powershell",
      "options": {
        "cwd": "${fileDirname}"
      },
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/latex_build_clean.ps1",
        "${fileDirname}",
        "${fileBasename}",
        "${fileBasenameNoExtension}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}
